---
# Generated at build time from _data/people.yml. Consumed by /assets/js/search.js.
# Do not edit this file by hand — edit _data/people.yml and rebuild.
permalink: /people.json
layout: null
---
[
{%- for p in site.data.people -%}
  {%- assign display = p.first -%}
  {%- if p.nickname and p.nickname != "" -%}{%- assign display = p.nickname -%}{%- endif -%}
  {%- capture meta -%}
    {%- if p.role == 'student' and p.grade -%}Grade {{ p.grade }}
    {%- elsif p.title -%}{{ p.title }}
    {%- elsif p.role == 'teacher' -%}Teacher
    {%- elsif p.role == 'staff' -%}Staff
    {%- endif -%}
  {%- endcapture -%}
  {
    "name": {{ display | append: " " | append: p.last | jsonify }},
    "search": {{ display | append: " " | append: p.last | append: " " | append: p.first | downcase | jsonify }},
    "meta": {{ meta | strip | jsonify }},
    "url": {{ p.id | prepend: "/people/" | append: "/" | relative_url | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
